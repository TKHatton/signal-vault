# ==============================================
# Signal Vault — Environment Variables
# ==============================================
# Copy this to .env.local and fill in your values

# Auth0 (Regular Web Application)
AUTH0_SECRET=           # Random secret for session encryption (use `openssl rand -hex 32`)
AUTH0_BASE_URL=http://localhost:3000
AUTH0_ISSUER_BASE_URL=  # https://your-tenant.auth0.com
AUTH0_CLIENT_ID=        # From Auth0 Dashboard > Applications
AUTH0_CLIENT_SECRET=    # From Auth0 Dashboard > Applications
AUTH0_AUDIENCE=         # https://signal-vault.api (or your custom API identifier)
AUTH0_SCOPE=openid profile email

# Auth0 Custom API Client (for Token Vault M2M exchange)
AUTH0_CUSTOM_API_CLIENT_ID=
AUTH0_CUSTOM_API_CLIENT_SECRET=

# Supabase (shared with ss-client-portal)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI (for LangGraph LLM)
OPENAI_API_KEY=

# Tenant
TENANT_ID=484fb776-2077-410f-a4dd-1432df766103
